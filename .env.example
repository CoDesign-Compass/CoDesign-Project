# Copy this file to `.env` and fill in real values.

# Resend API key used by backend GiftEmailService.
# Replace re_xxxxxxxxx with your real Resend API key.
RESEND_API_KEY=re_xxxxxxxxx

# Optional: sender address shown in outgoing emails.
# Must be a sender/domain verified in Resend for production sending.
APP_MAIL_FROM=compass@purposemediacbr.au
